<!DOCTYPE html>
<html lang="es" class="h-full bg-slate-900 overflow-hidden">
<head>
    <meta charset="[CharSet]">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>[eMuleAppName] [version] - Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .text-glow { text-shadow: 0 0 15px rgba(99, 102, 241, 0.4); }
    </style>
</head>
<body class="h-full flex items-center justify-center p-6 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900 via-slate-900 to-slate-950" onload="document.login.p.focus();">
    <div class="max-w-md w-full glass p-10 rounded-[3rem] shadow-[0_35px_60px_-15px_rgba(0,0,0,0.5)] space-y-8 animate-in fade-in zoom-in duration-700">
        <div class="text-center">
            <div class="inline-flex p-5 rounded-3xl bg-indigo-500/10 mb-6 group transition-all duration-500 hover:bg-indigo-500/20">
                <img src="logo.jpg" alt="eMule" class="h-16 w-auto drop-shadow-2xl grayscale hover:grayscale-0 transition-all">
            </div>
            <h2 class="text-4xl font-extrabold text-white tracking-tight text-glow">[WebControl]</h2>
            <p class="text-slate-400 mt-3 font-medium tracking-wide">[Login]</p>
        </div>
        
        <form action="" method="POST" name="login" class="space-y-6">
            <input type="hidden" name="w" value="password">
            <div class="relative group">
                <label for="p" class="block text-xs font-bold text-slate-500 uppercase tracking-[0.2em] ml-2 mb-2 group-focus-within:text-indigo-400 transition-colors uppercase">[EnterPassword]</label>
                <input type="password" name="p" id="p" maxlength="12" 
                    class="w-full px-6 py-4 rounded-2xl bg-slate-800/40 border-2 border-slate-700/50 text-white placeholder-slate-600 focus:outline-none focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-center tracking-[0.5em]"
                    placeholder="••••••••">
            </div>
            <button type="submit" 
                class="w-full py-4 px-6 bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-400 text-white font-bold rounded-2xl shadow-xl shadow-indigo-500/20 transform transition-all active:scale-[0.97] hover:shadow-indigo-500/40">
                [LoginNow]
            </button>
        </form>
        
        <div class="text-center text-[10px] text-slate-600 font-mono uppercase tracking-[0.3em] pt-6 border-t border-white/5">
            [eMuleAppName] <span class="text-indigo-500/50">[version]</span>
        </div>
    </div>
</body>
</html>
<--TMPL_LOGIN_END-->

