<--TMPL_GRAPHS-->
<script language="JavaScript">
function traceGraph(SpeedString,imageURL,MaxSpeed,color) {
    document.write('<div class="flex items-end h-[150px] w-full gap-[1px] bg-slate-950/30 p-2 rounded-2xl border border-white/5">');
    var speed = SpeedString.split(",");
    if(MaxSpeed==0) MaxSpeed = 1;
    for(i=0;i<speed.length;i++)
    {
        speed[i]=new Number(speed[i]);
        if (speed[i]>MaxSpeed) speed[i]=MaxSpeed;
        size=Math.round(speed[i]*100/MaxSpeed);
        document.write('<div class="flex-1 bg-' + color + '-500/40 hover:bg-' + color + '-500 transition-all rounded-t-sm" style="height:' + size + '%" title="' + speed[i] + '"><\/div>');
    }
    document.write('<\/div>');
}
</script>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <div class="card rounded-[3rem] p-8 space-y-6">
        <h4 class="text-xs font-black text-indigo-400 uppercase tracking-widest flex justify-between items-center">
            [TxtDownload] <span class="text-[10px] text-slate-500 font-normal">Max: [MaxDownload]</span>
        </h4>
        <script>traceGraph("[GraphDownload]","","[MaxDownload]*1024","indigo");</script>
    </div>
    <div class="card rounded-[3rem] p-8 space-y-6">
        <h4 class="text-xs font-black text-emerald-400 uppercase tracking-widest flex justify-between items-center">
            [TxtUpload] <span class="text-[10px] text-slate-500 font-normal">Max: [MaxUpload]</span>
        </h4>
        <script>traceGraph("[GraphUpload]","","[MaxUpload]*1024","emerald");</script>
    </div>
    <div class="card rounded-[3rem] p-8 space-y-6">
        <h4 class="text-xs font-black text-amber-400 uppercase tracking-widest flex justify-between items-center">
            [TxtConnections] <span class="text-[10px] text-slate-500 font-normal">Max: [MaxConnections]</span>
        </h4>
        <script>traceGraph("[GraphConnections]","","[MaxConnections]","amber");</script>
    </div>
</div>
<--TMPL_GRAPHS_END-->

